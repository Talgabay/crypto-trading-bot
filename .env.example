# ── Exchange (PAPER / DEMO ONLY) ────────────────────────────────────────────
# Register a key at https://testnet.binance.vision/  (Spot Testnet)
EXCHANGE=binance
SANDBOX=true
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=

# ccxt set_sandbox_mode() still points at a deprecated host for Binance Spot.
# We override the base URLs explicitly. See ccxt issue #27266.
BINANCE_SANDBOX_REST_URL=https://testnet.binance.vision
BINANCE_SANDBOX_WS_URL=wss://testnet.binance.vision/ws

# ── Telegram co-pilot channel (optional but recommended) ────────────────────
# Create a bot via @BotFather, then get your chat id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App ─────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/bot.db
LOG_LEVEL=INFO
# Hard safety: must be 'paper'. Going live is deliberately NOT a UI toggle.
TRADING_MODE=paper
# true => real testnet feed + real testnet orders (requires the keys above).
# false => synthetic feed + simulated paper execution.
USE_LIVE=false
